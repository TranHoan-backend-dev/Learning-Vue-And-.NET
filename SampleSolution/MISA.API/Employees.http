@MISA.API_HostAddress = http://localhost:5119

### 1. Add New Employee (Happy Case)
# @name AddNewEmployee
# This test case adds a new employee with valid data.
POST {{MISA.API_HostAddress}}/v1/api/Employees
Content-Type: application/json

{
  "EmployeeCode": "NV-8888",
  "FullName": "Nguyễn Văn Hoàn",
  "Gender": 1,
  "Email": "hoannv@misa.com.vn",
  "Age": 22
}

### 2. Update Employee (Happy Case)
# @name UpdateEmployee
# Note: You need a valid Guid from your database to run this.
@EmployeeId = 00000000-0000-0000-0000-000000000000
PUT {{MISA.API_HostAddress}}/v1/api/Employees/{{EmployeeId}}
Content-Type: application/json

{
  "EmployeeCode": "NV-8888-Updated",
  "FullName": "Nguyễn Văn Hoàn Updated",
  "Gender": 0,
  "Email": "hoannv_updated@misa.com.vn",
  "Age": 23
}

### 3. Delete Employee
# @name DeleteEmployee
# Note: You need a valid Guid from your database to run this.
DELETE {{MISA.API_HostAddress}}/v1/api/Employees/{{EmployeeId}}
